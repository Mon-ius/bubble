  <diagram name="Math pipeline" id="bubble-math-pipeline">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="860" pageHeight="740" math="1" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ═══════════════════════════════════════════════
             Layer 1 — Market substrate · DLM 2005 (y 20–100)
             ═══════════════════════════════════════════════ -->
        <mxCell id="g-L1" value="Market substrate · DLM 2005" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#1e3a8a;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="780" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="n-params" value="&lt;b&gt;T = 10&lt;/b&gt; periods &#xa0;&#xa0; d ∈ {0, 20}¢ &#xa0;&#xa0; 𝔼[d] = 10¢" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="54" width="370" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="n-fv" value="&lt;b&gt;FV&lt;sub&gt;t&lt;/sub&gt; = 𝔼[d] · (T − t + 1)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="54" width="350" height="44" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════════════
             Layer 2 — Utility agent pipeline (y 140–220)
             ═══════════════════════════════════════════════ -->
        <mxCell id="g-L2" value="Utility agent pipeline · N = 6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#14532d;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="30" y="140" width="780" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="n-prior" value="Prior &#xa0; FV&lt;sub&gt;t&lt;/sub&gt; · (1 + b&lt;sub&gt;i&lt;/sub&gt; + ε) &#xa0; U&lt;sub&gt;L&lt;/sub&gt; / U&lt;sub&gt;N&lt;/sub&gt; / U&lt;sub&gt;A&lt;/sub&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="174" width="370" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="n-eu" value="EU(a) = p · U(w₁) + (1−p) · U(w₀) &#xa0; a* = argmax" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="440" y="174" width="350" height="44" as="geometry"/>
