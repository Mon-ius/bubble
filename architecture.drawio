          <mxGeometry x="920" y="300" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="n-belief" value="Belief blending&#xa;posterior = w&#xb7;prior + (1-w)&#xb7;avg(msgs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="390" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="n-deception" value="Deception (Lopez-Lira)&#xa;report&#x1d65; = &#x3bb;&#xb7;true&#x1d65; + (1-&#x3bb;)&#xb7;bias" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=10;" vertex="1" parent="1">
