             ═══════════════════════════════════════════════ -->
        <mxCell id="g-L3" value="Belief update · three plans + social learning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2f8;strokeColor=#db2777;fontColor=#831843;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
