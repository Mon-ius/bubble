          <mxGeometry x="460" y="40" width="900" height="420" as="geometry"/>
        </mxCell>
        <mxCell id="n-fund" value="Fundamentalist&#xa;buy if ask &lt; 0.98&#xb7;FV&#x209c;&#xa;sell if bid &gt; 1.02&#xb7;FV&#x209c;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="200" height="70" as="geometry"/>
        </mxCell>
