        </mxCell>
        <mxCell id="n-plan1" value="&lt;b&gt;Plan I · algorithmic&lt;/b&gt;&#xa;V&lt;sup&gt;post&lt;/sup&gt; = w · V&lt;sup&gt;prior&lt;/sup&gt; + (1−w) · m̄&#xa;w = 0.6 + 0.1 · min(3, k)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#db2777;fontColor=#831843;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="296" width="240" height="76" as="geometry"/>
        </mxCell>
        <mxCell id="n-plan2" value="&lt;b&gt;Plan II · LLM + forms&lt;/b&gt;&#xa;prompt ⊇ {U&lt;sub&gt;L&lt;/sub&gt;, U&lt;sub&gt;N&lt;/sub&gt;, U&lt;sub&gt;A&lt;/sub&gt;}&#xa;a* ← LLM(π&lt;sup&gt;II&lt;/sup&gt;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#db2777;fontColor=#831843;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="306" y="296" width="240" height="76" as="geometry"/>
        </mxCell>
        <mxCell id="n-plan3" value="&lt;b&gt;Plan III · LLM + label&lt;/b&gt;&#xa;prompt ⊇ risk label only&#xa;a* ← LLM(π&lt;sup&gt;III&lt;/sup&gt;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#db2777;fontColor=#831843;fontSize=10;" vertex="1" parent="1">
