        </mxCell>
        <mxCell id="n-zi" value="Random (ZI)&#xa;bid &#x223c; U[0.7&#xb7;FV, 1.1&#xb7;FV]&#xa;ask &#x223c; U[0.9&#xb7;FV, 1.3&#xb7;FV]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="920" y="80" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="n-dlm-novice" value="DLMTrader (roundsPlayed = 0)&#xa;trend-chase + ZI noise&#xa;no FV horizon, no late liquidation&#xa;bubble-prone behaviour" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="180" width="280" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="n-dlm-vet" value="DLMTrader (roundsPlayed &#x2265; 1)&#xa;prior = &#x3c6;(h)&#xb7;FV&#x209c;, h = T&#x2212;t+1&#xa;refuses overpay in late periods&#xa;liquidates remaining inventory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="180" width="280" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="n-switch" value="decide() {&#xa;  return roundsPlayed === 0&#xa;    ? inexperienced()&#xa;    : experienced()&#xa;}&#xa;endogenous &#x2014; never pre-labeled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfccb;strokeColor=#65a30d;fontColor=#365314;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1080" y="180" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="n-util" value="Utility (Lopez-Lira 2025)&#xa;prior = FV&#x209c;&#xb7;(1 + b + &#x3b5;)&#xa;risk: U&#x2097;, U&#x2099;, U&#x2090;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="300" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="n-eu" value="EU&#x209a; = p&#x202f;U(w&#x2081;) + (1-p)&#x202f;U(w&#x2080;)&#xa;a* = argmax EU" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="300" width="200" height="80" as="geometry"/>
        </mxCell>
