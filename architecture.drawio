<mxfile host="app.diagrams.net" modified="2026-04-11T00:00:00.000Z" agent="bubble-math" version="24.7.17" etag="bubble-math-arch-strict-dlm" type="device">
  <diagram name="Math pipeline" id="bubble-math-pipeline">
    <mxGraphModel dx="1200" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="1" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Group: Paper constants (DLM 2005) -->
        <mxCell id="g-paper" value="Paper constants &#x2014; Dufwenberg, Lindqvist &amp; Moore (2005) &#xa7;I" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#1e3a8a;fontStyle=1;fontSize=12;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="380" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="n-N" value="N = 6 subjects / session&#xa;same six play rounds 1&#x2013;3, replacement in round 4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="340" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="n-rounds" value="R = 4 rounds / session&#xa;round-end reset of cash + inventory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="340" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="n-bigT" value="T = 10&#xa;Asset life (periods)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="n-div" value="d &#x2208; {0, 20}&#xa;&#x1d53c;[d] = 10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="200" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="n-fv" value="FV&#x209c; = &#x1d53c;[d] &#xb7; (T &#x2212; t + 1)&#xa;resets at every round start" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="340" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="n-endow" value="Endowments (two-discrete)&#xa;type A: 200&#xa2; + 6 shares&#xa;type B: 600&#xa2; + 2 shares&#xa;both bundles &#x2261; 1000&#xa2; buy-and-hold value" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="340" height="50" as="geometry"/>
        </mxCell>

        <!-- Group: Session + treatment (right of paper constants) -->
