          <mxGeometry x="40" y="410" width="380" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="n-round4" value="Round 4 replacement&#xa;T2: replace 2 of 6 &#x2022; T4: replace 4 of 6&#xa;fresh subjects spliced in with roundsPlayed = 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#7f1d1d;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="450" width="340" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n-batch" value="Multi-session batch&#xa;10 sessions total = 5 T2 + 5 T4&#xa;synchronous Engine.runToEnd() loop&#xa;fresh seed + fresh sample per session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#7f1d1d;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="340" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="n-payoff" value="Payoff accounting&#xa;&#x03c0;&#x1d62; = &#x03a3;&#x1d63; final cash&#x1d63;,&#x1d62; + 500&#xa2; show-up" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#7f1d1d;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="590" width="340" height="50" as="geometry"/>
        </mxCell>

